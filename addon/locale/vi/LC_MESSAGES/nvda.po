#. Translators: name of the addon category that will appear in the input gestures section.
#: addon\globalPlugins\battery_check\__init__.py:51
#: addon\globalPlugins\battery_check\settings.py:15
msgid "Battery Check"
msgstr "Kiểm tra pin"

#. Se crea una instancia de sensors_battery para verificar si existe batería en el sistema.
#. Si no es así se emite un mensaje y se detiene la ejecución del método.
#. Translators: Message to inform the user that there is no battery in the system.
#: addon\globalPlugins\battery_check\__init__.py:83
msgid "No hay batería del sistema."
msgstr "Không có pin hệ thống."

#. Translators: Message to indicate that battery monitoring has started.
#: addon\globalPlugins\battery_check\__init__.py:91
msgid "Monitoreo de la batería iniciado."
msgstr "Quá trình giám sát pin đã bắt đầu."

#. Translators: Message to indicate that battery monitoring has finished.
#: addon\globalPlugins\battery_check\__init__.py:105
msgid "Monitoreo de la batería finalizado."
msgstr "Giám sát pin đã dừng."

#: addon\globalPlugins\battery_check\__init__.py:129
msgid "conectada"
msgstr "đã kết nối"

#: addon\globalPlugins\battery_check\__init__.py:129
msgid "desconectada"
msgstr "đã ngắt kết nối"

#: addon\globalPlugins\battery_check\__init__.py:129
#, python-brace-format
msgid "Batería {}."
msgstr "Pin {}."

#. Translators: Message to indicate to the user that their battery is fully charged.
#: addon\globalPlugins\battery_check\__init__.py:135
msgid "¡Batería cargada al límite!"
msgstr "Pin đã được sạc đến mức giới hạn!"

#: addon\globalPlugins\battery_check\__init__.py:142
msgid "Inicia o detiene el monitoreo de la batería"
msgstr "Bắt đầu hoặc dừng giám sát pin"

#: addon\globalPlugins\battery_check\settings.py:18
msgid "Monitorear la batería cuando inicie NVDA"
msgstr "Giám sát pin khi khởi động NVDA"

#: addon\globalPlugins\battery_check\settings.py:19
msgid "Monitorear automáticamente la batería cuando se conecte el cargador"
msgstr "Tự động giám sát pin khi kết nối bộ sạc"

#: addon\globalPlugins\battery_check\settings.py:20
msgid "Porcentaje de batería máximo desde que se empezará a emitir la alerta"
msgstr "Phần trăm pin tối đa kể từ khi cảnh báo bắt đầu được đưa ra"

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: buildVars.py:23
msgid "Monitoreo de batería"
msgstr "Kiểm tra pin"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:26
msgid ""
"La función de este addon es monitorear la batería del sistema y emitir un "
"aviso al esta llegar al 100%."
msgstr ""
"Chức năng của addon này là theo dõi pin hệ thống và đưa ra cảnh báo khi đạt "
"100%."
